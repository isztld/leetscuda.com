# ─── Required ────────────────────────────────────────────────────────────────

# Base URL of the web app. The judge posts results here and polls for jobs.
# Example: https://leetscuda.com
JUDGE_API_URL=

# Bearer token used to authenticate all requests to the web app.
# Must start with "jt_". Generate with: openssl rand -hex 32 | sed 's/^/jt_/'
JUDGE_API_TOKEN=

# Capabilities declared to the web app. Must include "k8s".
# This judge handles only k8s manifest validation; no other values are meaningful.
JUDGE_CAPABILITIES=k8s

# ─── Optional: limits ────────────────────────────────────────────────────────

# Hard ceiling on kubeconform execution time in milliseconds.
# Job payloads requesting a longer timeout are clamped to this value.
# Default: 30000
# JUDGE_MAX_TIMEOUT_MS=30000

# Hard ceiling on submitted YAML manifest size in bytes, checked before any
# parsing to prevent YAML bomb expansion. Default: 131072 (128 KiB)
# JUDGE_MAX_MANIFEST_BYTES=131072

# Hard ceiling on the number of checks per job payload.
# Jobs exceeding this limit are rejected with RUNTIME_ERROR. Default: 64
# JUDGE_MAX_CHECKS=64

# ─── Optional: infrastructure ────────────────────────────────────────────────

# Port for the local health check HTTP server used by Docker/k8s liveness probes.
# Returns 200 {"status":"ok","capabilities":["k8s"]} when the poll loop is alive.
# Default: 8081 (avoids collision with judge-cuda-cpp which uses 8080)
# JUDGE_HEALTH_PORT=8081
