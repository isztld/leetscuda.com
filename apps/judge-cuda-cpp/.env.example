# ─── Required ────────────────────────────────────────────────────────────────

# Base URL of the web app. The judge posts results here and polls for jobs.
# Example: https://leetscuda.com
JUDGE_API_URL=

# Bearer token used to authenticate all requests to the web app.
# Must start with "jt_". Generate with: openssl rand -hex 32 | sed 's/^/jt_/'
JUDGE_API_TOKEN=

# Comma-separated list of runtime capabilities this judge declares.
# The web app only dispatches jobs whose requirements fit within the declared
# capabilities. A CPU-only judge uses "cpp". A GPU judge adds the CUDA version
# and minimum compute capability: "cpp,cuda:13.0:sm_120"
JUDGE_CAPABILITIES=cpp

# ─── Optional: limits ────────────────────────────────────────────────────────

# Hard ceiling on per-test-case execution time in milliseconds.
# Job payloads requesting a longer timeout are clamped to this value.
# Default: 60000
# JUDGE_MAX_TIMEOUT_MS=60000

# Hard ceiling on submitted code payload size in bytes.
# Payloads exceeding this limit are rejected with RUNTIME_ERROR before any
# container is created. Default: 16384 (16 KiB)
# JUDGE_MAX_CODE_BYTES=16384

# ─── Optional: infrastructure ────────────────────────────────────────────────

# Port for the local health check HTTP server used by Docker/k8s liveness probes.
# Returns 200 {"status":"ok"} when the poll loop is alive. Default: 8080
# JUDGE_HEALTH_PORT=8080

# GPU device index passed to --gpus device=<N> for CUDA eval containers.
# Relevant only when JUDGE_CAPABILITIES includes a cuda:... entry. Default: 0
# JUDGE_GPU_DEVICE=0

# Docker socket proxy address. When set, the judge connects here instead of
# the default Unix socket. In production this should point to a
# docker-socket-proxy sidecar (see docker-compose.yml).
# If unset, the judge falls back to the local Unix socket and logs a warning.
# Example: tcp://127.0.0.1:2375
# DOCKER_HOST=tcp://127.0.0.1:2375
