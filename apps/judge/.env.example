JUDGE_API_URL=https://leetscuda.com
JUDGE_API_TOKEN=jt_...
# Judge capabilities (comma-separated)
# Format: cpp | cuda:{version}:{sm_cap} | k8s
# Examples:
#   CPU only:     JUDGE_CAPABILITIES=cpp
#   Blackwell:    JUDGE_CAPABILITIES=cpp,cuda:13.0:sm_120
#   Ampere:       JUDGE_CAPABILITIES=cpp,cuda:12.6:sm_86
#   Hopper:       JUDGE_CAPABILITIES=cpp,cuda:12.3:sm_90
JUDGE_CAPABILITIES=
# Docker host — point to socket proxy for hardened deployment.
# docker-compose.judge.yml sets this automatically via the socket-proxy service.
# For local development only (less secure): leave unset to use the default socket.
DOCKER_HOST=tcp://127.0.0.1:2375
# Hard ceiling on execution timeout in milliseconds — cannot be exceeded regardless of job payload
JUDGE_MAX_TIMEOUT_MS=60000
# Hard ceiling on code payload size in bytes — job payloads cannot exceed this
JUDGE_MAX_CODE_BYTES=16384
