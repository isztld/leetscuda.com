JUDGE_API_URL=https://leetscuda.com
JUDGE_API_TOKEN=jt_...
JUDGE_CAPABILITIES=cpp,cuda:13.0
# Required when running the judge inside Docker with the host Docker socket (DinD-style).
# Set to the absolute host path of apps/judge/tmp, then mount it at /app/apps/judge/tmp.
# docker run ... -v /your/repo/apps/judge/tmp:/app/apps/judge/tmp
JUDGE_HOST_TMP_DIR=/your/repo/apps/judge/tmp
# Hard ceiling on execution timeout in milliseconds — cannot be exceeded regardless of job payload
JUDGE_MAX_TIMEOUT_MS=60000
# Hard ceiling on code payload size in bytes — job payloads cannot exceed this
JUDGE_MAX_CODE_BYTES=16384
