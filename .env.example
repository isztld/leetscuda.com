NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# DATABASE_URL — used by prisma.config.ts for migrations (direct connection, port 5432)
# DIRECT_URL   — used by the pg adapter at runtime (pooler URL, port 6543)
#                If unset, falls back to DATABASE_URL
#
# Local Postgres (no pooler — both are the same):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leetscuda
#
# Supabase:
#   DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.com:5432/postgres
#   DIRECT_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-x-xx-west-x.pooler.supabase.com:6543/postgres
DATABASE_URL=
DIRECT_URL=
REDIS_URL=redis://localhost:6379

# Submission limits
# Daily limit for free users (0 = unlimited)
SUBMISSION_DAILY_LIMIT_FREE=10
# Daily limit for paid/admin users (0 = unlimited)
SUBMISSION_DAILY_LIMIT_PAID=0
# Maximum code size in bytes (default: 16 KB)
SUBMISSION_MAX_CODE_BYTES=16384
# Per-minute submission rate limit per user (burst protection)
SUBMISSION_RATE_LIMIT_PER_MIN=5
# Default judge timeout in milliseconds
SUBMISSION_TIMEOUT_MS=30000
# Hard ceiling on judge timeout — requests cannot exceed this
SUBMISSION_MAX_TIMEOUT_MS=60000

# Maintenance
JUDGE_SUBMISSIONS_DISABLED=false
