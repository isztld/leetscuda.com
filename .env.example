NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# connection_limit=10 prevents exhausting Supabase free-tier's 60-connection cap
# pool_timeout=20 avoids hanging on a connection that never becomes available
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leetscuda?connection_limit=10&pool_timeout=20
REDIS_URL=redis://localhost:6379

# Submission limits
# Daily limit for free users (0 = unlimited)
SUBMISSION_DAILY_LIMIT_FREE=10
# Daily limit for paid/admin users (0 = unlimited)
SUBMISSION_DAILY_LIMIT_PAID=0
# Maximum code size in bytes (default: 16 KB)
SUBMISSION_MAX_CODE_BYTES=16384
# Per-minute submission rate limit per user (burst protection)
SUBMISSION_RATE_LIMIT_PER_MIN=5
# Default judge timeout in milliseconds
SUBMISSION_TIMEOUT_MS=30000
# Hard ceiling on judge timeout — requests cannot exceed this
SUBMISSION_MAX_TIMEOUT_MS=60000
